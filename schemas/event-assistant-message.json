{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnas.dev/schemas/event-assistant-message.json",
  "title": "Harnas assistant_message Event payload",
  "oneOf": [
    {
      "title": "Canonical content-block payload",
      "type": "object",
      "additionalProperties": false,
      "required": ["content", "stop_reason", "usage"],
      "properties": {
        "content": {
          "type": "array",
          "items": { "$ref": "content-block.json" }
        },
        "stop_reason": {
          "type": "string",
          "enum": ["end_turn", "max_tokens", "tool_use", "stop_sequence", "refusal", "other"]
        },
        "usage": {
          "oneOf": [
            { "$ref": "usage.json" },
            {
              "description": "Legacy pre-v0.19 usage payload.",
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "reasoning": {
          "$ref": "#/$defs/reasoning"
        },
        "provider_items": {
          "type": "array",
          "items": { "$ref": "provider-carrier.json" }
        }
      }
    },
    {
      "title": "Legacy text payload",
      "description": "Read-only compatibility shape. New runtimes write content instead.",
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "stop_reason", "usage"],
      "properties": {
        "text": { "type": "string" },
        "stop_reason": {
          "type": "string",
          "enum": ["end_turn", "max_tokens", "tool_use", "stop_sequence", "refusal", "other"]
        },
        "usage": {
          "oneOf": [
            { "$ref": "usage.json" },
            {
              "description": "Legacy pre-v0.19 usage payload.",
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "reasoning": {
          "$ref": "#/$defs/reasoning"
        },
        "provider_items": {
          "type": "array",
          "items": { "$ref": "provider-carrier.json" }
        }
      }
    }
  ],
  "$defs": {
    "reasoning": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "text"],
        "properties": {
          "type": { "const": "text" },
          "text": { "type": "string" },
          "signature": { "type": "string" },
          "provider_parts": {
            "type": "array",
            "items": { "$ref": "provider-carrier.json" }
          }
        }
      }
    }
  }
}
