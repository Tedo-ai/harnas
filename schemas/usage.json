{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnas.dev/schemas/usage.json",
  "title": "Harnas canonical provider usage metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "input_tokens",
    "output_tokens",
    "total_tokens",
    "cache_read_input_tokens",
    "cache_write_input_tokens",
    "reasoning_tokens",
    "provider_raw",
    "provenance"
  ],
  "properties": {
    "input_tokens": { "type": "integer", "minimum": 0 },
    "output_tokens": { "type": "integer", "minimum": 0 },
    "total_tokens": { "type": "integer", "minimum": 0 },
    "cache_read_input_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "cache_write_input_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "reasoning_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "provider_raw": { "type": ["object", "null"], "additionalProperties": true },
    "provenance": {
      "type": "string",
      "enum": ["provider_reported", "runtime_estimated", "unavailable"]
    }
  }
}
