{
  "harnas_version": "0.1",
  "name": "with-repetition-guard-rejections",
  "provider": {
    "kind": "openai",
    "model": "gpt-test",
    "max_tokens": 1024
  },
  "tools": [
    {
      "name": "dangerous_tool",
      "handler": "conformance.dangerous_tool",
      "description": "A tool denied by fixture policy.",
      "input_schema": {
        "type": "object",
        "properties": {
          "target": { "type": "string" }
        },
        "required": ["target"]
      }
    }
  ],
  "strategies": [
    {
      "name": "Permission::DenyByName",
      "config": {
        "names": ["dangerous_tool"]
      }
    },
    {
      "name": "guard/repetition",
      "config": {
        "max_consecutive_failures": 10,
        "max_identical_calls": 10,
        "max_consecutive_rejections": 3
      }
    }
  ]
}

