{
  "harnas_version": "0.1",
  "name": "with-write-sandbox-deny",
  "provider": {
    "kind": "openai",
    "model": "gpt-test",
    "max_tokens": 1024
  },
  "tools": [
    {
      "name": "write_file",
      "handler": "harnas.builtin.write_file",
      "description": "Write text content to a file at the given path.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "content": { "type": "string" }
        },
        "required": ["path", "content"]
      }
    }
  ],
  "strategies": [
    {
      "name": "sandbox/write",
      "config": {
        "allow": ["."],
        "deny": ["./secrets"]
      }
    }
  ]
}
